        {
          "id": "feature-3",
          "type": "container",
          "props": {
            "style": "padding:1.5rem;border:1px solid #e5e7eb;border-radius:12px;background:#fff"
          },
          "children": [
            {
              "id": "feature-3-heading",
              "type": "heading",
