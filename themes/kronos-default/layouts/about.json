              }
            },
            {
              "id": "about-cta",
              "type": "button",
              "props": {
                "text": "View on GitHub",
                "url": "https://github.com/TheoSfak/KronosCms",
                "style": "margin-top:1.5rem;display:inline-block;background:#1e3a8a;color:#fff;padding:.75rem 1.75rem;border-radius:8px;text-decoration:none;font-weight:600"
              }
            }
          ]
        },
        {
          "id": "about-image-col",
          "type": "image",
          "props": {
            "src": "",
            "alt": "KronosCMS Dashboard Screenshot",
            "style": "width:100%;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,.12)"
          }
        }
