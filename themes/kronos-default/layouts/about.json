          "props": { "style": "" },
          "children": [
            {
              "id": "about-heading",
              "type": "heading",
              "props": { "level": 1, "text": "About KronosCMS" }
            },
            {
              "id": "about-text-1",
              "type": "text",
              "props": { "text": "KronosCMS is a standalone PHP 8 content management and e-commerce platform with no WordPress dependency. It was designed to be lightweight, extensible, and developer-friendly." }
