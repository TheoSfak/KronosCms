# KronosCMS Environment Configuration
# Copy this file to .env and fill in your values. Never commit .env to version control.

# Application
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost/KronosCMS/public

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=kronos_cms
DB_USER=root
DB_PASS=

# Security
JWT_SECRET=change-this-to-a-long-random-string-at-least-64-chars
JWT_EXPIRY=86400

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Stripe
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

# Marketplace Hub
HUB_API_URL=http://localhost/KronosCMS/public/hub-mock/

# GitHub (for update checker)
GITHUB_REPO=TheoSfak/KronosCms
